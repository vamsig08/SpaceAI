# SpaceAI Backend Configuration
# Copy this file to .env and adjust values

# Application
SPACEAI_ENV=development
SPACEAI_DEBUG=true
SPACEAI_HOST=0.0.0.0
SPACEAI_PORT=8000

# Database
SPACEAI_DB_PATH=./data/spaceai.db

# Scanner
SPACEAI_SCANNER_BATCH_SIZE=1000
SPACEAI_SCANNER_CHECKPOINT_INTERVAL=10000
SPACEAI_SCANNER_THREAD_POOL_SIZE=4

# AI Provider
SPACEAI_AI_PROVIDER=ollama
SPACEAI_OPENAI_API_KEY=
SPACEAI_OPENAI_MODEL=gpt-4o
SPACEAI_OLLAMA_BASE_URL=http://localhost:11434
SPACEAI_OLLAMA_MODEL=llama3

# Logging
SPACEAI_LOG_LEVEL=DEBUG

# Cleanup
SPACEAI_TRASH_RETENTION_DAYS=30
